generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("LOCAL_DATABASE_URL")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model comment_scrape_logs {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String?   @db.Uuid
  post_shortcode   String?   @db.VarChar(255)
  api_calls        Int?      @default(0)
  comments_scraped Int?      @default(0)
  scraped_at       DateTime? @default(now()) @db.Timestamptz(6)

  @@index([post_shortcode], map: "idx_comment_scrape_logs_post")
  @@ignore
}

model comments {
  id              String    @id @db.VarChar(255)
  post_shortcode  String    @db.VarChar(255)
  username        String?   @db.VarChar(255)
  user_id         String?   @db.VarChar(255)
  text            String?
  likes_count     Int?      @default(0)
  reply_count     Int?      @default(0)
  profile_pic_url String?
  commented_at    DateTime? @db.Timestamptz(6)
  scraped_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@index([post_shortcode], map: "idx_comments_post")
  @@index([username], map: "idx_comments_username")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model ig_users {
  id                String    @id @db.VarChar(255)
  username          String    @db.VarChar(255)
  follower_count    BigInt?   @default(0)
  following_count   BigInt?   @default(0)
  media_count       Int?      @default(0)
  biography         String?
  external_url      String?
  business_category String?   @db.VarChar(255)
  is_verified       Boolean?  @default(false)
  role              String?   @default("reference") @db.VarChar(50)
  scraped_at        DateTime? @default(now()) @db.Timestamptz(6)

  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model post_metrics_history {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_shortcode   String?   @db.VarChar(255)
  likes_count      Int?      @default(0)
  comments_count   Int?      @default(0)
  video_view_count Int?      @default(0)
  captured_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@index([post_shortcode], map: "idx_metrics_post")
  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model post_relations {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_shortcode String? @db.VarChar(255)
  username       String? @db.VarChar(255)
  relation_type  String  @db.VarChar(50)

  @@index([post_shortcode], map: "idx_relations_post")
  @@index([username], map: "idx_relations_user")
  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model posts {
  shortcode            String    @id @db.VarChar(255)
  owner_username       String?   @db.VarChar(255)
  post_url             String?
  caption              String?
  image_url            String?
  video_url            String?
  is_video             Boolean?  @default(false)
  is_carousel          Boolean?  @default(false)
  is_paid              Boolean?  @default(false)
  classification       String?   @default("Normal Post") @db.VarChar(100)
  type                 String?   @default("normal") @db.VarChar(50)
  collective_reach     BigInt?   @default(0)
  reach_breakdown      Json?     @default("[]")
  scraped_from_profile String?   @db.VarChar(255)
  is_reference         Boolean?  @default(false)
  posted_at            DateTime? @db.Timestamptz(6)
  first_captured_at    DateTime? @default(now()) @db.Timestamptz(6)
  last_updated_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@index([owner_username], map: "idx_posts_owner")
  @@index([type], map: "idx_posts_type")
  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model project_posts {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id     String    @db.Uuid
  post_shortcode String    @db.VarChar(255)
  added_at       DateTime? @default(now()) @db.Timestamptz(6)

  @@index([post_shortcode], map: "idx_project_posts_post")
  @@index([project_id], map: "idx_project_posts_project")
  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model project_profiles {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id String    @db.Uuid
  username   String    @db.VarChar(255)
  role       String?   @default("tracked") @db.VarChar(50)
  added_at   DateTime? @default(now()) @db.Timestamptz(6)
