# Copy to .env and fill in real local credentials.
# The database NAME at the end of each URL is the database that will be created.
# Note: '&' in a password must be percent-encoded as %26.

TIKSURFER_DATABASE_URL=postgresql://devuser:PASSWORD@localhost:5432/Tik_Surfer_multi_fix
INSTA_DATABASE_URL=postgresql://devuser:PASSWORD@localhost:5432/insta_surf_multi_prisma
