# Tik Surfer Backend — environment template.
# Copy this file to `.env` (and/or `.env.local`) and fill in real values.
# NEVER commit `.env` or `.env.local` — they are gitignored.

# --- Database --------------------------------------------------------------
# If LOCAL_DATABASE_URL is set, it is used. URL-encode special chars (e.g. & -> %26).
LOCAL_DATABASE_URL=postgresql://user:password@localhost:5432/your_database

# Production/fallback database (used when LOCAL_DATABASE_URL is unset)
# DATABASE_URL=postgresql://user:password@host:5432/your_database

# --- Server ----------------------------------------------------------------
PORT=3001

# --- Auth ------------------------------------------------------------------
# REQUIRED. The server refuses to start if this is unset (no insecure default).
# Generate a strong value, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Admin panel password — use a strong, unique value.
ADMIN_PASSWORD=

# Optional API key (must match what the extension sends), leave blank to disable.
API_KEY=
