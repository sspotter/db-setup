{
  "name": "insta-surfer-backend",
  "version": "1.0.0",
  "description": "Backend API for Insta Surfer Chrome Extension — stores captured Instagram data in PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently -k -n server,studio -c blue,magenta \"npm:dev:server\" \"npm:prisma:studio\"",
    "dev:server": "node --watch server.js",
    "prisma:pull": "prisma db pull",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio --port 5556",
    "test": "jest"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "jimp": "^0.16.13",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "jest": "^29.7.0",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2"
  }
}
