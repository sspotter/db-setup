{
  "name": "tiksurfer-backend",
  "version": "1.0.0",
  "description": "Backend API for the Tik Surfer Chrome Extension — stores captured TikTok data in PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:init": "node building/create_db.js",
    "db:migrate": "node migrations/run_v3_migration.js",
    "test": "jest"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "jimp": "^0.16.13",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  }
}
