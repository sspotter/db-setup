/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model projects {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid
  name        String    @db.VarChar(255)
  description String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@index([user_id], map: "idx_projects_user")
  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model scrape_jobs {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id       String    @db.Uuid
  post_shortcode   String    @db.VarChar(255)
  page_number      Int?      @default(1)
  status           String?   @default("pending") @db.VarChar(50)
  end_cursor       String?   @default("")
  comments_scraped Int?      @default(0)
  retry_count      Int?      @default(0)
  max_retries      Int?      @default(3)
  error_message    String?
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  started_at       DateTime? @db.Timestamptz(6)
  completed_at     DateTime? @db.Timestamptz(6)

  @@index([post_shortcode], map: "idx_scrape_jobs_post")
  @@index([session_id], map: "idx_scrape_jobs_session")
  @@index([status], map: "idx_scrape_jobs_status")
  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model scrape_sessions {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String?   @db.Uuid
  profile_username       String?   @db.VarChar(255)
  status                 String?   @default("pending") @db.VarChar(50)
  total_posts            Int?      @default(0)
  total_jobs             Int?      @default(0)
  completed_jobs         Int?      @default(0)
  total_comments_scraped Int?      @default(0)
  created_at             DateTime? @default(now()) @db.Timestamptz(6)
  started_at             DateTime? @db.Timestamptz(6)
  completed_at           DateTime? @db.Timestamptz(6)
  project_id             String?   @db.Uuid

  @@index([project_id], map: "idx_scrape_sessions_project")
  @@index([status], map: "idx_scrape_sessions_status")
  @@index([user_id], map: "idx_scrape_sessions_user")
  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model user_scraped_posts {
